<mxGraphModel><root><mxCell id="0"/><mxCell id="1" parent="0"/>

<!-- Title -->
<mxCell id="title" value="Cache 模拟器 — 可配置 Cache 架构与访问流程" style="text;fontSize=18;fontStyle=1;align=center;fillColor=none;" vertex="1" parent="1">
  <mxGeometry x="130" y="8" width="540" height="32" as="geometry"/>
</mxCell>

<!-- ===== 地址分解 ===== -->
<mxCell id="addr-title" value="32位地址分解 (例: 16KB / 4-way / 32B Block → 128 Sets)" style="text;fontSize=13;fontStyle=1;align=center;fillColor=none;" vertex="1" parent="1">
  <mxGeometry x="160" y="50" width="480" height="24" as="geometry"/>
</mxCell>

<mxCell id="tag-block" value="Tag (20 bits)&#xa;用于比较匹配" style="rounded=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
  <mxGeometry x="40" y="82" width="200" height="44" as="geometry"/>
</mxCell>
<mxCell id="idx-block" value="Index (7 bits)&#xa;选择 Cache Set" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
  <mxGeometry x="265" y="82" width="140" height="44" as="geometry"/>
</mxCell>
<mxCell id="off-block" value="Offset (5 bits)&#xa;块内字节偏移" style="rounded=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
  <mxGeometry x="430" y="82" width="140" height="44" as="geometry"/>
</mxCell>
<mxCell id="formula" value="num_sets = 16KB÷(4×32B) = 128&#xa;offset = log₂(32) = 5 bits&#xa;index = log₂(128) = 7 bits&#xa;tag = 32−7−5 = 20 bits" style="rounded=1;fillColor=#FFF;strokeColor=#999;fontSize=9;align=left;" vertex="1" parent="1">
  <mxGeometry x="605" y="76" width="175" height="56" as="geometry"/>
</mxCell>

<mxCell id="addr-arrow" style="endArrow=classic;strokeColor=#333;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="idx-block" target="set0-label">
  <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="335" y="140"/><mxPoint x="160" y="140"/><mxPoint x="160" y="148"/></Array></mxGeometry>
</mxCell>

