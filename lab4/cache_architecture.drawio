  <mxGeometry x="400" y="322" width="150" height="50" as="geometry"/>
</mxCell>

<!-- Arrows: st1→st2→st3 -->
<mxCell id="ar12" style="endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="st1" target="st2">
