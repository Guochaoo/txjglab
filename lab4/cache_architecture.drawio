<!-- LRU注释 -->
<mxCell id="lru-note" value="▲ LRU=3最小 → 淘汰Way1 (D=1需先写回)" style="text;fontSize=9;fillColor=#FFF9C4;strokeColor=#F57F17;dashed=1;align=center;" vertex="1" parent="1">
